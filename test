"use client"

import { useEffect, useState } from "react"
import Image from "next/image"

type FloatingItem = {
  id: number
  src: string
  alt: string
  startX: number
  startY: number
  baseScale: number
  rotation: number
  speed: number
}

const floatingImages = [
  { src: "/images/A89BCD82-5DB9-4FFD-BA4B-1261FBA5B947.png", alt: "Hologram Dress 1" },
  { src: "/images/A31E8023-EB03-46ED-B000-745DCB855891.png", alt: "Hologram Dress 2" },
  { src: "/images/96320B25-7203-4C1B-80B8-E91AB0729FAE.png", alt: "Constellation Dress" },
  { src: "/images/2D236DBE-9E76-4CC5-994A-11F076CE2624.png", alt: "Soft Stardust Dress" },
]

export default function HeroFloating() {
  const [scrollY, setScrollY] = useState(0)
  const [floatingItems, setFloatingItems] = useState<FloatingItem[]>([])

  useEffect(() => {
    const handleScroll = () => setScrollY(window.scrollY)
    window.addEventListener("scroll", handleScroll)

    const items: FloatingItem[] = floatingImages.map((img, index) => {
      const angle = (index / floatingImages.length) * Math.PI * 2
      const radius = 10 + Math.random() * 15

      return {
        id: index,
        src: img.src,
        alt: img.alt,
        startX: 50 + Math.cos(angle) * radius,
        startY: 50 + Math.sin(angle) * radius,
        baseScale: 0.2 + Math.random() * 0.2,
        rotation: Math.random() * 20 - 10,
        speed: 0.6 + Math.random() * 0.4,
      }
    })

    setFloatingItems(items)

    return () => window.removeEventListener("scroll", handleScroll)
  }, [])

  return (
    <div className="relative w-screen h-[200vh] bg-black overflow-hidden">

      {/* LOGO CENTER */}
      <div className="fixed inset-0 flex items-center justify-center z-50 pointer-events-none">
        <Image
          src="/images/23BBFD80-C82B-4BBA-8423-138B4C5BB65A.png"
          alt="MedaStaré"
          width={300}
          height={300}
          priority
          className="opacity-90"
        />
      </div>

      {/* FLOATING ITEMS */}
      <div className="fixed inset-0 pointer-events-none">
        {floatingItems.map((item) => {

          const scale = item.baseScale + scrollY * 0.001 * item.speed
          const opacity = 1 - scrollY * 0.0015
          const spread = 1 + scrollY * 0.002

          const x = 50 + (item.startX - 50) * spread
          const y = 50 + (item.startY - 50) * spread

          if (opacity <= 0) return null

          return (
            <div
              key={item.id}
              style={{
                position: "absolute",
                left: `${x}%`,
                top: `${y}%`,
                transform: `
                  translate(-50%, -50%)
                  scale(${scale})
                  rotate(${item.rotation}deg)
                `,
                opacity: opacity,
                transition: "transform 0.1s linear, opacity 0.2s",
              }}
            >
              <Image
                src={item.src}
                alt={item.alt}
                width={250}
                height={250}
              />
            </div>
          )
        })}
      </div>

    </div>
  )
}
